# Copy to .env and adjust for your setup

# --- Scraper ---
# Tier 1 (cloud):  BURBLE_BASE_URL=https://burble.com
# Tier 2 (local):  BURBLE_BASE_URL=http://192.168.1.x
# Tier 3 (manual): leave blank — use POST /api/loads instead
BURBLE_BASE_URL=https://burble.com
BURBLE_POLL_INTERVAL_MINUTES=2

# --- Storage ---
# Absolute path on the host (bind-mounted into the backend container)
VIDEO_STORAGE_PATH=/mnt/ssd/videos
# Where the OS mounts SD cards (e.g. /media on Raspberry Pi OS)
SD_CARD_WATCH_PATH=/media

# --- Database ---
# SQLite file inside the db-data named volume
DATABASE_URL=sqlite+aiosqlite:////data/skybox.db
